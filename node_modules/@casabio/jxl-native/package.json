{
  "name": "@casabio/jxl-native",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "gypfile": true,
  "scripts": {
    "build": "node-gyp rebuild",
    "build:prebuild": "prebuildify --napi --strip",
    "build:prebuild:linux": "prebuildify --napi --strip --platform linux --arch x64 --arch arm64",
    "build:prebuild:darwin": "prebuildify --napi --strip --platform darwin --arch x64 --arch arm64",
    "build:prebuild:win": "prebuildify --napi --strip --platform win32 --arch x64",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "node-gyp": "12.3.0",
    "prebuildify": "6.0.1",
    "typescript": "5.5.4"
  }
}
