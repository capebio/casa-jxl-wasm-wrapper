{
  "name": "@casabio/jxl-worker-browser",
  "version": "0.1.0",
  "description": "DedicatedWorker host for WASM JXL codec sessions (browser)",
  "type": "module",
  "sideEffects": ["./dist/worker.js"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test --test-isolation=none --test-force-exit dist-test/test/*.test.js"
  },
  "dependencies": {
    "@casabio/jxl-core": "^0.1.0",
    "@casabio/jxl-capabilities": "^0.1.0",
    "@casabio/jxl-wasm": "^0.1.0"
  },
  "devDependencies": {
    "typescript": "5.5.4"
  }
}
