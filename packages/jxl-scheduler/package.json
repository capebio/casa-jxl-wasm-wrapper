{
  "name": "@casabio/jxl-scheduler",
  "version": "0.1.0",
  "description": "Worker pool, priority lanes, preemption, dedupe, and budget enforcement for the Casabio JXL wrapper",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test --test-force-exit dist-test/test/*.test.js"
  },
  "dependencies": {
    "@casabio/jxl-core": "^0.1.0"
  },
  "devDependencies": {
    "typescript": "5.5.4",
    "@types/node": "^22.12.0"
  }
}
