{
  "name": "@casabio/jxl-native",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "gypfile": true,
  "scripts": {
    "build": "node-gyp rebuild",
    "prebuild": "prebuildify --napi --strip",
    "prebuild:linux": "prebuildify --napi --strip --platform linux --arch x64 --arch arm64",
    "prebuild:darwin": "prebuildify --napi --strip --platform darwin --arch x64 --arch arm64",
    "prebuild:win": "prebuildify --napi --strip --platform win32 --arch x64",
    "typecheck": "tsc --noEmit"
  }
}
