{
  "name": "@casabio/jxl-session",
  "version": "0.1.0",
  "description": "Session facade for the Casabio JXL wrapper — the only module callers import to drive codec work",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "browser": "./dist/browser.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test --test-force-exit dist-test/test/*.test.js"
  },
  "dependencies": {
    "@casabio/jxl-capabilities": "^0.1.0",
    "@casabio/jxl-core": "^0.1.0",
    "@casabio/jxl-scheduler": "^0.1.0",
    "@casabio/jxl-worker-browser": "^0.1.0",
    "@casabio/jxl-worker-node": "^0.1.0"
  },
  "devDependencies": {
    "typescript": "5.5.4",
    "@types/node": "^22.12.0"
  }
}
