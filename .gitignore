.worktrees/
.epiccodereview/
tmp/
.codex-tmp/
**/__pycache__/

# flipflop timing vehicle
.flipflop/
flipflop-corpus/

# ============================================================================
# Build artifacts, dependencies, and runtime profiles
# (These were accidentally committed in the past; this .gitignore + rm --cached
#  cleans the index so future merges and clones stay lean.)
# ============================================================================

# JS / monorepo dependencies (workspaces populate these)
node_modules/

# Rust build artifacts (Cargo target dir)
target/
.cargo-home/
.codex-cargo-target-*/
# Generated threaded-wasm pkg (build with tools/build-mt-wasm.sh)
pkg-mt/

# Temporary / scratch (already partially ignored; ensure all)
tmp/

# Browser / test automation profiles (Playwright, CDP, persistent contexts)
bun-chrome-*/
node-cdp-*/
bun-persistent-*/

# Agent / review / automation worktrees and scratch
.claude/worktrees/
.epiccodereview/
docs/superpowers/          # planning artifacts from superpowers/ skill (ephemeral; see docs/references/historical/)

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*~

# Logs and error dumps
*.log
debug.log
build errors*.log
build errors.run.log

# Python
**/__pycache__/
*.py[cod]
*$py.class

# Vendored sources (jpegxl-rs vendored, cargo vendor, etc.)
vendor/*
# Exception: jpegxl-src build-glue crate is patched in-tree ([patch.crates-io] in
# Cargo.toml) to force MSVC /O2 on the libjxl release build (without it, libjxl 0.11.x
# builds unoptimized → ~30x slower encode/decode). Tracked so the patch resolves on
# clone/CI. Glue only (~35K); libjxl source is the external/libjxl submodule.
!vendor/jpegxl-src/

# Benchmark / experimental output (generated by various benchmark scripts)
benchmark/runs/
benchmark/option-matrix*.mjs
benchmark/inspect-image.mjs
benchmark/matrix-view.mjs
docs/TAURI_OPTION_MATRIX_BENCHMARK.md
docs/outputs/
test-images/

# One-off correlation matrix experiments
web/jxl-correlation-matrix.html
web/jxl-correlation-matrix.js
.worktrees/

# Research papers (large PDFs, ~57MB; kept on disk, not tracked to keep clones lean)
Papers/
